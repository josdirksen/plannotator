{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@plannotator/shared/*": ["../../packages/shared/*"],
      "@plannotator/ui/*": ["../../packages/ui/*"],
      "@plannotator/canvas-editor": ["../../packages/canvas-editor/App.tsx"],
      "@plannotator/canvas-editor/styles": ["../../packages/canvas-editor/index.css"]
    }
  },
  "include": ["index.tsx", "../../packages/canvas-editor/**/*.ts", "../../packages/canvas-editor/**/*.tsx"]
}
