    <script is:inline>
      // AnnoReplace interaction
      (function() {
        var trigger = document.getElementById('anno-replace-trigger');
        var popover = document.getElementById('anno-replace-popover');
        if (!trigger || !popover) return;
        var glove = document.getElementById('anno-glove');
        var closeBtn = document.getElementById('anno-replace-close');
        trigger.addEventListener('click', function() {
          trigger.classList.remove('anno-shimmer');
          trigger.classList.add('clicked');
          if (glove) glove.classList.add('hidden');
          popover.classList.add('visible');
        });
        if (closeBtn) {
          closeBtn.addEventListener('click', function() {
            popover.classList.remove('visible');
            trigger.classList.remove('clicked');
            trigger.classList.add('anno-shimmer');
            if (glove) glove.classList.remove('hidden');
          });
        }
      })();

      // Mobile nav scroll
      (function() {
        var nav = document.getElementById('v3-nav');
        if (!nav) return;
        window.addEventListener('scroll', function() {
          nav.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
        }, { passive: true });
      })();

      // GitHub star count
      (function() {
        var star = document.getElementById('v3-star');
        var num = document.getElementById('v3-star-num');
        if (!star || !num) return;
        fetch('https://api.github.com/repos/backnotprop/plannotator')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(d) {
            if (!d || typeof d.stargazers_count !== 'number') return;
            var n = d.stargazers_count;
            num.textContent = n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : String(n);
            star.hidden = false;
          })
          .catch(function() {});
      })();

      // How it works toggle (plan review / code review)
      (function() {
        var planSteps = [
          'Work with your coding agent exactly as you do today. When it proposes a plan, Plannotator intercepts the approval step automatically.',
          'Instead of squinting at terminal text, you get a proper review workspace. Annotate inline, mark what needs to change, then approve or deny with structured feedback. You own the specification.',
          'Your annotations are sent directly to the agent as structured feedback. No copy-pasting, no retyping. The agent revises based on exactly what you said.'
        ];
        var codeSteps = [
          'Your agent writes code. Run the review command and Plannotator opens a full diff viewer in your browser with every uncommitted change.',
          'Browse the file tree, expand context, and leave line-level comments or code suggestions. Stage the files you want, send back the ones that need work.',
          'Your feedback goes straight to the agent. It sees exactly which lines you commented on and what you want changed. No ambiguity.'
        ];

        document.querySelectorAll('.hiw-toggle-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var mode = btn.dataset.hiw;
            document.querySelectorAll('.hiw-toggle-btn').forEach(function(b) {
              b.classList.toggle('active', b.dataset.hiw === mode);
              b.setAttribute('aria-selected', b.dataset.hiw === mode ? 'true' : 'false');
            });

            var planImg = document.getElementById('hiw-img-plan');
            var codeImg = document.getElementById('hiw-img-code');
            var barTitle = document.querySelector('.hiw-bar-title');
            if (planImg && codeImg) {
              planImg.classList.toggle('hidden', mode === 'code');
              codeImg.classList.toggle('hidden', mode === 'plan');
            }
            if (barTitle) {
              barTitle.innerHTML = mode === 'plan'
                ? 'Plannotator · Plan Review'
                : 'Plannotator · Code Review';
            }

            var steps = mode === 'plan' ? planSteps : codeSteps;
            for (var i = 0; i < 3; i++) {
              var el = document.getElementById('hiw-step-' + (i + 1));
              if (el) el.textContent = steps[i];
            }
          });
        });
      })();

      // Plan review terminal demo: starts on viewport entry
      (function() {
        var demo = document.getElementById('plan-demo');
        var terminal = document.getElementById('plan-demo-terminal');
        var screen = document.getElementById('plan-demo-screen');
        var image = document.getElementById('plan-demo-image');
        var typed = document.getElementById('plan-demo-typed');
        var caret = document.getElementById('plan-demo-caret');
        var output = document.getElementById('plan-demo-output');
        var ascii = document.getElementById('plan-demo-ascii');
        var denyBtn = document.getElementById('plan-demo-deny');
        var glove = document.getElementById('plan-demo-glove');
        if (!demo || !terminal || !screen || !image || !typed || !caret || !output || !denyBtn) return;

        var active = false;
        var timers = [];

        function delay(fn, ms) {
          var t = setTimeout(fn, ms);
          timers.push(t);
          return t;
        }

        function clearTimers() {
          timers.forEach(clearTimeout);
          timers = [];
        }

        function typeText(el, text, speed, cb) {
          var i = 0;
          function tick() {
            if (!active) return;
            if (i < text.length) {
              el.textContent += text[i];
              i++;
              delay(tick, speed);
            } else if (cb) { cb(); }
          }
          tick();
        }

        function resetDemo() {
          clearTimers();
          typed.textContent = '';
          output.innerHTML = '';
          caret.classList.remove('hidden');
          if (ascii) ascii.style.opacity = '1';
          if (glove) glove.classList.remove('visible');
          image.classList.remove('plan-demo-visible');
          terminal.classList.remove('plan-demo-faded');
        }

        function showImage() {
          terminal.classList.add('plan-demo-faded');
          image.classList.add('plan-demo-visible');
          if (glove) delay(function() { glove.classList.add('visible'); }, 600);
        }

        function showTerminal() {
          image.classList.remove('plan-demo-visible');
          terminal.classList.remove('plan-demo-faded');
        }

        function showOutput(text, cls) {
          var line = document.createElement('div');
          if (cls) line.className = cls;
          line.textContent = text;
          output.appendChild(line);
          screen.scrollTop = screen.scrollHeight;
        }

        function runPhase1() {
          if (!active) return;
          resetDemo();
          active = true;
          delay(function() {
            if (!active) return;
            if (ascii) ascii.style.opacity = '0.4';
            delay(function() {
              if (!active) return;
              typeText(typed, '/plannotator-annotate spec.md', 55, function() {
                delay(function() {
                  if (!active) return;
                  caret.classList.add('hidden');
                  delay(function() {
                    if (!active) return;
                    showOutput('... reading spec.md', 'plan-demo-step');
                    delay(function() {
                      if (!active) return;
                      showOutput('... rendering markdown', 'plan-demo-step');
                      delay(function() {
                        if (!active) return;
                        showOutput('... opening review surface', 'plan-demo-step');
                        delay(function() {
                          if (!active) return;
                          showOutput('annotate ready', 'plan-demo-submit');
                          delay(function() { if (active) showImage(); }, 900);
                        }, 900);
                      }, 800);
                    }, 800);
                  }, 600);
                }, 700);
              });
            }, 400);
          }, 1200);
        }

        function runPhase2() {
          if (!active) return;
          if (glove) glove.classList.remove('visible');
          showTerminal();
          typed.textContent = '';
          output.innerHTML = '';
          caret.classList.add('hidden');
          if (ascii) ascii.style.opacity = '0.4';
          typed.textContent = '...';
          screen.scrollTop = screen.scrollHeight;
          delay(function() {
            if (!active) return;
            showOutput('→ Annotations sent to agent', 'text-primary');
            delay(function() {
              if (!active) return;
              showOutput('"Tighten the auth section,', 'text-primary');
              delay(function() {
                if (!active) return;
                showOutput('drop the extra dependency."', 'text-primary');
                delay(function() {
                  if (!active) return;
                  showOutput('Addressing feedback...', 'text-success');
                  delay(runPhase1, 3000);
                }, 800);
              }, 500);
            }, 700);
          }, 800);
        }

        denyBtn.addEventListener('click', runPhase2);

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !active) {
              active = true;
              delay(runPhase1, 600);
            } else if (!entry.isIntersecting && active) {
              active = false;
              clearTimers();
              resetDemo();
            }
          });
        }, { threshold: 0.6 });
        observer.observe(demo);
      })();

      // Code review terminal demo: starts on viewport entry
      (function() {
        var demo = document.getElementById('code-demo');
        var terminal = document.getElementById('code-demo-terminal');
        var screen = document.getElementById('code-demo-screen');
        var image = document.getElementById('code-demo-image');
        var typed = document.getElementById('code-demo-typed');
        var caret = document.getElementById('code-demo-caret');
        var output = document.getElementById('code-demo-output');
        var ascii = document.getElementById('code-demo-ascii');
        var sendBtn = document.getElementById('code-demo-send');
        var glove = document.getElementById('code-demo-glove');
        if (!demo || !terminal || !screen || !image || !typed || !caret || !output || !sendBtn) return;

        var active = false;
        var timers = [];

        function delay(fn, ms) {
          var t = setTimeout(fn, ms);
          timers.push(t);
          return t;
        }

        function clearTimers() {
          timers.forEach(clearTimeout);
          timers = [];
        }

        function typeText(el, text, speed, cb) {
          var i = 0;
          function tick() {
            if (!active) return;
            if (i < text.length) {
              el.textContent += text[i];
              i++;
              delay(tick, speed);
            } else if (cb) { cb(); }
          }
          tick();
        }

        function resetDemo() {
          clearTimers();
          typed.textContent = '';
          output.innerHTML = '';
          caret.classList.remove('hidden');
          if (ascii) ascii.style.opacity = '1';
          if (glove) glove.classList.remove('visible');
          image.classList.remove('plan-demo-visible');
          terminal.classList.remove('plan-demo-faded');
        }

        function showImage() {
          terminal.classList.add('plan-demo-faded');
          image.classList.add('plan-demo-visible');
          if (glove) delay(function() { glove.classList.add('visible'); }, 600);
        }

        function showTerminal() {
          image.classList.remove('plan-demo-visible');
          terminal.classList.remove('plan-demo-faded');
        }

        function addLine(text, cls) {
          var line = document.createElement('div');
          if (cls) line.className = cls;
          line.textContent = text;
          output.appendChild(line);
          screen.scrollTop = screen.scrollHeight;
        }

        function runPhase1() {
          if (!active) return;
          resetDemo();
          active = true;
          delay(function() {
            if (!active) return;
            if (ascii) ascii.style.opacity = '0.4';
            delay(function() {
              if (!active) return;
              typeText(typed, '/plannotator-review', 60, function() {
                delay(function() {
                  if (!active) return;
                  caret.classList.add('hidden');
                  addLine('Loading diff...', 'plan-demo-step');
                  delay(function() { if (active) showImage(); }, 800);
                }, 600);
              });
            }, 400);
          }, 1200);
        }

        function runPhase2() {
          if (!active) return;
          if (glove) glove.classList.remove('visible');
          showTerminal();
          typed.textContent = '';
          output.innerHTML = '';
          caret.classList.add('hidden');
          if (ascii) ascii.style.opacity = '0.4';
          typed.textContent = '...';
          screen.scrollTop = screen.scrollHeight;
          delay(function() {
            if (!active) return;
            addLine('Feedback sent to agent', 'text-primary');
            delay(function() {
              if (!active) return;
              addLine('2 comments, 1 suggestion', 'plan-demo-step');
              delay(function() {
                if (!active) return;
                addLine('Addressing feedback...', 'text-success');
                delay(runPhase1, 3000);
              }, 800);
            }, 600);
          }, 800);
        }

        sendBtn.addEventListener('click', runPhase2);

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !active) {
              active = true;
              delay(runPhase1, 600);
            } else if (!entry.isIntersecting && active) {
              active = false;
              clearTimers();
              resetDemo();
            }
          });
        }, { threshold: 0.6 });
        observer.observe(demo);
      })();

    </script>

  </body>
</html>
