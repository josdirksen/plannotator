---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';

const waitlistUrl =
  import.meta.env.PUBLIC_WAITLIST_URL ||
  'https://plannotator-waitlist.plannotator.workers.dev';

// Cloudflare Turnstile sitekey. Public by design — embedded in the rendered
// HTML on every visit. Override at build time via PUBLIC_TURNSTILE_SITEKEY
// if you spin up a separate widget. Set to '' to disable the widget locally.
const turnstileSitekey =
  import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '0x4AAAAAADUgxk47fMzTYOZp';

// Display strings shown in the UI; the slug is what we send to the worker.
const teamSizes = [
  { slug: 'solo',    label: 'Just me' },
  { slug: '2-5',     label: '2–5' },
  { slug: '6-20',    label: '6–20' },
  { slug: '21-50',   label: '21–50' },
  { slug: '50+',     label: '50+' },
];
---
<Base
  title="Plannotator Workspaces · Get notified"
  description="Plannotator Workspaces is the hosted team layer for collaborating on agent plans, specs, code reviews, and verification standards. Plannotator core stays free and open source."
  themeClass="theme-plandromeda"
>
  <Fragment slot="head">
  </Fragment>

  <div class="ws-page-scope min-h-screen bg-background text-foreground font-['Inter',system-ui,sans-serif]">

    <div class="ws-root">
      <div class="ws-split">

        <!-- LEFT — sticky, like v3 landing -->
        <div class="ws-left">
          <a href="/" class="ws-logo">Plannotator</a>

          <div class="ws-left-content">
            <p class="ws-eyebrow"><span class="ws-eyebrow-shimmer">Workspaces · Waitlist</span></p>
            <h1 class="ws-page-title">From review surfaces to standards your agents learn from.</h1>
            <p class="ws-body">
              The hosted team layer for agent plans, code reviews, and verification standards. The local plugin stays free & open source.
            </p>
          </div>

          <div class="ws-phases-compact">
            <div class="ws-phase-item">
              <span class="ws-phase-when">Today</span>
              <span class="ws-phase-what">You review agent artifacts and code.</span>
            </div>
            <div class="ws-phase-item">
              <span class="ws-phase-when">Next</span>
              <span class="ws-phase-what">Artifacts become versioned standards accessible to agents and teammates.</span>
            </div>
            <div class="ws-phase-item">
              <span class="ws-phase-when">Compound</span>
              <span class="ws-phase-what">Standards get checked before and after code lands. Enhanced gating for PRs and releases.</span>
            </div>
          </div>

          <div class="ws-left-links">
            <a href="/">Home</a>
            <a href="/docs/getting-started/installation/">Docs</a>
            <a href="https://github.com/backnotprop/plannotator" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>

        <!-- RIGHT — scrollable cards, like v3 landing -->
        <div class="ws-right">
        <form class="ws-form-card" id="signup-form" novalidate>
          <header class="ws-form-head">
            <h2 class="ws-form-title">Get notified</h2>
          </header>

          <div class="ws-form-body">
            <div class="ws-honeypot" aria-hidden="true">
              <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div class="ws-field">
              <label class="ws-label">Email</label>
              <input type="email" name="email" placeholder="jane@company.com" autocomplete="email" maxlength="320" />
            </div>

            <div class="ws-row-2">
              <div class="ws-field">
                <label class="ws-label">Company <span class="ws-opt">optional</span></label>
                <input type="text" name="company" placeholder="Acme Inc." autocomplete="organization" maxlength="160" />
              </div>
              <div class="ws-field">
                <label class="ws-label">Team size</label>
                <div class="ws-pills" data-field="teamSize" data-single="1">
                  {teamSizes.map((t) => (
                    <button type="button" class="ws-pill" data-v={t.slug}>{t.label}</button>
                  ))}
                </div>
              </div>
            </div>

            <div
              class="ws-check-row"
              id="contributor-toggle"
              role="checkbox"
              aria-checked="false"
              tabindex="0"
            >
              <span class="ws-box" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span>OSS contributor: <span class="ws-accent">lifetime free access</span></span>
            </div>

            <div class="ws-form-foot">
              <button type="submit" class="ws-submit">
                <span class="ws-submit-idle">
                  <span>Join waitlist</span>
                  <svg class="ws-arrow w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </span>
                <span class="ws-submit-busy" aria-hidden="true">
                  <span class="ws-spinner"></span>
                  <span class="ws-submit-busy-label">Submitting…</span>
                </span>
              </button>
            </div>

            {turnstileSitekey && (
              <div
                id="ws-turnstile"
                class="cf-turnstile ws-turnstile"
                data-sitekey={turnstileSitekey}
                data-callback="onWsTurnstile"
                data-expired-callback="onWsTurnstileExpired"
                data-error-callback="onWsTurnstileError"
                data-theme="auto"
                data-retry="auto"
              />
            )}
          </div>

          <div class="ws-success">
            <div class="ws-ok">
              <span class="ws-dot" aria-hidden="true"></span>
              <span id="ok-stamp">SIGNUP CONFIRMED</span>
            </div>
            <h3 class="ws-success-title">
              You're on the list, <em id="ok-name">friend</em>.
            </h3>
            <p>
              We'll email <strong id="ok-email">your address</strong> when the
              next cohort opens. Expect a real note from a human, not a
              marketing sequence.
            </p>
            <p id="ok-contrib-note">
              Contributing meaningful PRs to the OSS core qualifies you for
              lifetime free access on Teams.
            </p>
            <div class="ws-receipt" id="receipt"></div>
          </div>
        </form>

        <!-- Offerings card -->
        <div class="ws-card">
          <div class="ws-card-body">
            <p class="ws-card-label">What you get</p>
            <div class="ws-offerings">
              <div>
                <p class="ws-offering-title">Collaborative knowledge base<span class="ws-star">✱</span></p>
                <p class="ws-offering-desc">Share plans, specs, and reviews with your team and agents.</p>
              </div>
              <div>
                <p class="ws-offering-title">Annotations become standards</p>
                <p class="ws-offering-desc">Capture review comments as reusable expectations for future work.</p>
              </div>
              <div>
                <p class="ws-offering-title">Golden standards<span class="ws-star">✱</span></p>
                <p class="ws-offering-desc">Extract verification facts from specs and reviews into rules your agents rely on.</p>
              </div>
              <div>
                <p class="ws-offering-title">Feed back into agents</p>
                <p class="ws-offering-desc">Send accumulated knowledge into planning and review agents.</p>
              </div>
              <div>
                <p class="ws-offering-title">CI/CD integration</p>
                <p class="ws-offering-desc">PR explainers, plan context, and verification against standards.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Open source card -->
        <div class="ws-card">
          <div class="ws-card-body">
            <span class="ws-commit-tag">[ open source ]</span>
            <p class="ws-commit-msg">
              Plannotator core stays <em>free and open source</em>, always.
              Workspaces is the hosted layer for teams.
            </p>
          </div>
        </div>

        <!-- OSS contributor card -->
        <div class="ws-oss-note">
          <span class="ws-oss-note-label">↳ OSS contributors</span>
          Early contributors receive
          <span class="ws-accent">lifetime free access</span>. Flag yourself
          in the form above.
        </div>

        </div>
      </div>
    </div>
  </div>

  {turnstileSitekey && (
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    />
  )}

  <script
    is:inline
    define:vars={{ waitlistUrl, turnstileEnabled: !!turnstileSitekey }}
  >
    (function () {
      var form = document.getElementById('signup-form');
      if (!form) return;

      var turnstileEl = document.getElementById('ws-turnstile');
      var turnstileToken = null;
      var turnstileWaiters = [];
      var isSubmitting = false;
      var fields = { teamSize: '' };
      var contributor = false;

      window.onWsTurnstile = function (token) {
        // Useful breadcrumb when debugging signup failures from devtools.
        console.info('[waitlist] turnstile token received');
        turnstileToken = token;
        var waiters = turnstileWaiters;
        turnstileWaiters = [];
        waiters.forEach(function (resolve) { resolve(token); });
      };
      window.onWsTurnstileExpired = function () {
        console.info('[waitlist] turnstile token expired');
        turnstileToken = null;
        if (window.turnstile && turnstileEl) {
          try { window.turnstile.reset(turnstileEl); } catch (_) {}
        }
      };
      window.onWsTurnstileError = function (err) {
        console.warn('[waitlist] turnstile error:', err);
        turnstileToken = null;
      };

      // Resolves with `{ token, reason }`. `reason` is null on success,
      // 'no-script' if the Turnstile API never loaded (usually a content
      // blocker), 'timeout' if it loaded but didn't issue a token in time.
      function awaitTurnstileToken() {
        if (!turnstileEnabled) return Promise.resolve({ token: null, reason: null });
        if (turnstileToken) return Promise.resolve({ token: turnstileToken, reason: null });

        if (!window.turnstile) {
          // Script never executed — extension blocked it, or the user is
          // offline. Surface a clear, actionable error instead of a generic
          // "couldn't verify" 400 from the worker.
          return Promise.resolve({ token: null, reason: 'no-script' });
        }
        if (turnstileEl) {
          try { window.turnstile.execute(turnstileEl); } catch (_) {}
        }
        return new Promise(function (resolve) {
          var done = false;
          turnstileWaiters.push(function (token) {
            if (done) return;
            done = true;
            resolve({ token: token, reason: null });
          });
          // 10s gives Turnstile plenty of time on slow networks. Most
          // legit visitors get a token in well under 1s.
          setTimeout(function () {
            if (done) return;
            done = true;
            resolve({ token: null, reason: 'timeout' });
          }, 10000);
        });
      }

      // Pill picker
      document.querySelectorAll('.ws-pills').forEach(function (group) {
        var key = group.dataset.field;
        var single = group.dataset.single === '1';
        group.addEventListener('click', function (e) {
          var p = e.target.closest('.ws-pill');
          if (!p) return;
          var v = p.dataset.v;
          if (single) {
            group.querySelectorAll('.ws-pill').forEach(function (x) {
              x.classList.remove('on');
              x.setAttribute('aria-pressed', 'false');
            });
            p.classList.add('on');
            p.setAttribute('aria-pressed', 'true');
            fields[key] = v;
          }
          clearErr(group);
        });
      });

      // Contributor toggle (click + keyboard)
      var contribEl = document.getElementById('contributor-toggle');
      function toggleContributor() {
        contributor = !contributor;
        contribEl.classList.toggle('on', contributor);
        contribEl.setAttribute('aria-checked', contributor ? 'true' : 'false');
      }
      if (contribEl) {
        contribEl.addEventListener('click', toggleContributor);
        contribEl.addEventListener('keydown', function (e) {
          if (e.key === ' ' || e.key === 'Enter') {
            e.preventDefault();
            toggleContributor();
          }
        });
      }

      function clearErr(el) {
        var f = el.closest('.ws-field');
        if (!f) return;
        var existing = f.querySelector('.ws-err');
        if (existing) existing.remove();
      }
      function showErr(el, msg) {
        clearErr(el);
        var f = el.closest('.ws-field');
        if (!f) return;
        var e = document.createElement('div');
        e.className = 'ws-err';
        e.textContent = '↳ ' + msg;
        f.appendChild(e);
      }
      function clearAllFormErrors() {
        form.querySelectorAll('.ws-err').forEach(function (n) { n.remove(); });
      }

      form.querySelectorAll('input, textarea').forEach(function (el) {
        el.addEventListener('input', function () { clearErr(el); });
      });

      function setBusy(busy, label) {
        var btn = form.querySelector('.ws-submit');
        if (!btn) return;
        btn.disabled = busy;
        btn.classList.toggle('is-loading', busy);
        if (busy) {
          var labelEl = btn.querySelector('.ws-submit-busy-label');
          if (labelEl && label) labelEl.textContent = label;
        }
      }

      function teamSizeLabel(slug) {
        var pill = form.querySelector('[data-field="teamSize"] [data-v="' + slug + '"]');
        return pill ? pill.textContent : slug;
      }

      function renderReceipt(data) {
        var company = data.company;
        // Derive a 2-letter sigil from email + company. Email gives the user's
        // initial, company gives the org's. Avoids needing the user's name.
        var emailInitial = (data.email.charAt(0) || 'X').toUpperCase();
        var companyInitial = (company.charAt(0) || 'X').toUpperCase();
        var id = 'WL-' + Math.floor(Math.random() * 9000 + 1000) + '-' +
          emailInitial + companyInitial;
        var pos = Math.floor(Math.random() * 240 + 380);

        // Address by the email-local-part as a friendly fallback for "name".
        var greeting = data.email.split('@')[0] || 'friend';
        document.getElementById('ok-name').textContent = greeting;
        document.getElementById('ok-email').textContent = data.email;
        document.getElementById('ok-stamp').textContent =
          'SIGNUP CONFIRMED · ' + new Date().toISOString().slice(0, 10);
        if (data.is_contributor) {
          document.getElementById('ok-contrib-note').textContent =
            "Since you contribute to the core, you'll hear from us about lifetime access shortly.";
        }

        var receipt = document.getElementById('receipt');
        var rows = [
          ['ticket', id],
          ['company', company],
          ['team size', teamSizeLabel(data.team_size)],
          ['cohort position', '~#' + pos],
          ['oss contributor', data.is_contributor ? 'yes, flagged for review' : 'no'],
        ];
        receipt.innerHTML = rows.map(function (r) {
          return '<div class="ws-r"><span class="ws-r-k">' + r[0] +
            '</span><span class="ws-r-v">' + (r[1] || '-') + '</span></div>';
        }).join('');
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (isSubmitting) return;
        clearAllFormErrors();

        var get = function (n) { return form.querySelector('[name="' + n + '"]'); };
        var email = (get('email').value || '').trim();
        var company = (get('company').value || '').trim();
        var note = (get('note').value || '').trim();
        var team_size = fields.teamSize;

        var ok = true;
        if (!email) { showErr(get('email'), 'Required'); ok = false; }
        else if (!/^[^\s@]+@[^\s@.]+\.[^\s@]+$/.test(email)) {
          showErr(get('email'), 'Looks invalid'); ok = false;
        }
        // Company is presented as optional in the UI. The worker still
        // requires a non-empty value, so stub one here when the user
        // leaves it blank — keeps the server contract untouched.
        if (!company) company = '(not provided)';
        if (!team_size) {
          showErr(form.querySelector('[data-field="teamSize"]'), 'Pick one');
          ok = false;
        }
        if (!ok) return;

        var payload = {
          email: email,
          company: company,
          team_size: team_size,
          note: note || undefined,
          is_contributor: contributor,
          website: (get('website') && get('website').value) || '',
        };

        isSubmitting = true;
        setBusy(true, turnstileEnabled ? 'Verifying…' : 'Submitting…');

        awaitTurnstileToken()
          .then(function (result) {
            if (result.reason === 'no-script') {
              showErr(get('email'),
                "Couldn't load Cloudflare's verification. Try disabling your ad/content blocker for this site, then retry.");
              return null;
            }
            if (result.reason === 'timeout') {
              showErr(get('email'),
                'Verification timed out. Refresh the page and try again.');
              if (window.turnstile && turnstileEl) {
                try { window.turnstile.reset(turnstileEl); } catch (_) {}
              }
              return null;
            }
            // Token may be null when Turnstile is disabled entirely; that's
            // fine — the worker won't enforce verification in that mode.
            if (result.token) payload.turnstile_token = result.token;
            setBusy(true, 'Submitting…');
            return fetch(waitlistUrl + '/signup', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
          })
          .then(function (res) {
            if (!res) return null; // Turnstile failure — already surfaced.
            return res.json().then(function (body) { return { res: res, body: body }; });
          })
          .then(function (result) {
            if (!result) return; // Turnstile failure path.
            if (!result.res.ok) {
              var msg = (result.body && result.body.error) || 'Something went wrong. Please try again.';
              showErr(get('email'), msg);
              if (turnstileEnabled && window.turnstile && turnstileEl) {
                turnstileToken = null;
                try { window.turnstile.reset(turnstileEl); } catch (_) {}
              }
              return;
            }
            renderReceipt(payload);
            form.classList.add('ws-submitted');
          })
          .catch(function () {
            showErr(get('email'), "Couldn't reach the waitlist server. Try again.");
          })
          .finally(function () {
            isSubmitting = false;
            setBusy(false);
          });
      });
    })();
  </script>

  <script is:inline>
    (function() {
      var nav = document.getElementById('ws-nav');
      if (!nav) return;
      window.addEventListener('scroll', function() {
        nav.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
      }, { passive: true });
    })();
  </script>

  <style>
    /* ── V3-aligned styles ── */
    .ws-page-scope {
      --radius: 0.75rem;
    }
    .ws-page-scope::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 256px 256px;
    }

    /* ── V3-style split layout ── */
    .ws-root {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    @media (min-width: 810px) {
      .ws-root { padding: 0 24px; }
    }

    .ws-split {
      display: flex;
      flex-flow: column;
      gap: 24px;
      width: 100%;
      padding-top: 60px;
    }
    @media (min-width: 810px) {
      .ws-split {
        flex-flow: row;
        align-items: flex-start;
        gap: 100px;
        padding-top: 0;
      }
    }

    .ws-left {
      display: flex;
      flex-flow: column;
      align-items: flex-start;
      gap: 24px;
      padding-top: 24px;
      width: 100%;
    }
    @media (min-width: 810px) {
      .ws-left {
        max-width: 350px;
        flex: 1 0 0;
        width: 1px;
        position: sticky;
        top: 0;
        height: 100dvh;
        justify-content: flex-start;
        padding-top: 80px;
      }
    }

    .ws-right {
      display: flex;
      flex-flow: column;
      align-items: center;
      gap: 10px;
      width: 100%;
      max-width: 480px;
      padding: 12px 0 80px;
    }
    @media (min-width: 810px) {
      .ws-right {
        flex: 1 0 0;
        width: 1px;
        padding: 80px 0 120px;
      }
    }

    /* ── Logo ── */
    .ws-logo {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--foreground);
      text-decoration: none;
    }

    /* ── Left content ── */
    .ws-left-content {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ws-body {
      font-size: 14px;
      line-height: 22px;
      color: color-mix(in oklab, var(--foreground) 60%, transparent);
    }

    /* ── Phases compact ── */
    .ws-phases-compact {
      display: flex;
      flex-direction: column;
      gap: 0;
      width: 100%;
      border-top: 1px solid color-mix(in oklab, var(--border) 50%, transparent);
    }
    .ws-phase-item {
      display: flex;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px dashed color-mix(in oklab, var(--border) 40%, transparent);
      font-size: 13px;
      line-height: 1.4;
    }
    .ws-phase-when {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-weight: 600;
      color: var(--secondary);
      min-width: 72px;
      flex-shrink: 0;
      font-size: 13px;
    }
    .ws-phase-what {
      color: color-mix(in oklab, var(--foreground) 55%, transparent);
    }

    /* ── Left links ── */
    .ws-left-links {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 12px;
    }
    .ws-left-links a {
      color: color-mix(in oklab, var(--foreground) 40%, transparent);
      text-decoration: none;
      transition: color 0.15s;
    }
    .ws-left-links a:hover {
      color: color-mix(in oklab, var(--foreground) 70%, transparent);
    }

    /* ── V3-style cards ── */
    .ws-card {
      width: 100%;
      border-radius: 12px;
      overflow: hidden;
      background: var(--card);
      border: 1px solid var(--border);
    }
    .ws-card-body {
      padding: 24px;
    }
    @media (min-width: 810px) {
      .ws-card-body { padding: 32px; }
    }
    .ws-card-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: color-mix(in oklab, var(--foreground) 30%, transparent);
      margin-bottom: 16px;
    }

    /* ── Offerings list ── */
    .ws-offerings {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .ws-offering-title {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--foreground);
    }
    .ws-offering-desc {
      font-size: 13px;
      color: color-mix(in oklab, var(--foreground) 50%, transparent);
      line-height: 1.4;
      margin-top: 1px;
    }

    /* ── Two independent column flow ──
       Each column flows on its own — left column has hero on top with
       info content below; right column has form on top with banners
       below. Hero and form are top-aligned siblings since both columns
       start at the top. (Grid-template-areas couldn't do this — shared
       rows forced empty space below the shorter sibling.)

       On mobile (≤ 980px) the columns "open up" via `display: contents`
       so their children become flex items of `.ws-main`, which lets us
       reorder to: hero → form → info → banners. Form is lifted ahead of
       the long info content; banners drop to the very bottom.

       Top padding stays at 80px on every breakpoint so the .ws-eyebrow
       always clears the 48px fixed Nav with comfortable breathing room. */
    .ws-main {
      max-width: 1060px;
      margin: 0 auto;
      padding: 80px 24px;
      display: flex;
      gap: 60px;
      align-items: stretch;
    }
    .ws-col-left {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      /* Breathing room between the hero (eyebrow + h1) and the first
         "Today" row of the phases list — without this the title's
         descenders run into the dashed grid above "Today". */
      gap: 32px;
    }
    .ws-col-right {
      flex: 0 0 440px;
      min-width: 0;
      display: flex;
      flex-direction: column;
      /* Generous spacing between the form-card and the banners stack
         so the form has clear visual breathing room as the CTA. */
      gap: 32px;
      /* Push the form-card down so its top edge lines up with the h1
         next door, not the eyebrow above it. ~ eyebrow line-height
         (15px × 1.55) + its 16px margin-bottom. */
      padding-top: 40px;
    }
    .ws-banners {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    @media (max-width: 980px) {
      .ws-main {
        flex-direction: column;
        gap: 40px;
        padding: 80px 28px 56px;
      }
      /* Flatten the column wrappers so their children become direct flex
         items of .ws-main — this is what makes the cross-column reorder
         (hero → form → info → banners) possible. The desktop padding-top
         on .ws-col-right is irrelevant here since the wrapper itself is
         dissolved by display:contents. */
      .ws-col-left,
      .ws-col-right { display: contents; }
      .ws-hero    { order: 1; }
      .ws-form-card { order: 2; }
      .ws-info    { order: 3; }
      .ws-banners { order: 4; }
    }
    @media (max-width: 600px) {
      .ws-main { padding: 80px 20px 56px; }
    }

    /* ── Eyebrow shimmer ── */
    .ws-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin: 0;
    }
    .ws-eyebrow-shimmer {
      background: linear-gradient(
        90deg,
        #3b82f6 0%,
        #93c5fd 25%,
        #60a5fa 50%,
        #93c5fd 75%,
        #3b82f6 100%
      );
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: ws-shimmer-blue 6s linear infinite;
    }
    @keyframes ws-shimmer-blue {
      0% { background-position: 0% center; }
      100% { background-position: 200% center; }
    }
    .ws-page-title {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 24px;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--foreground);
      margin: 0;
    }
    @media (min-width: 810px) {
      .ws-page-title { font-size: 28px; }
    }

    /* ── Phases (Today / Next / Compound) ── */
    .ws-phases {
      display: grid;
      grid-template-columns: 110px 1fr;
      max-width: 560px;
      margin-bottom: 4px;
    }
    .ws-phase { display: contents; }
    .ws-phase .ws-when,
    .ws-phase .ws-what {
      padding: 12px 0;
      border-top: 1px dashed oklch(from var(--border) l c h / 0.5);
    }
    .ws-phase:first-child .ws-when,
    .ws-phase:first-child .ws-what { border-top: none; padding-top: 2px; }
    .ws-when {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--secondary);
      letter-spacing: -0.005em;
      padding-left: 14px;
    }
    .ws-what {
      font-size: 14px;
      line-height: 22px;
      color: color-mix(in oklab, var(--foreground) 60%, transparent);
    }
    @media (max-width: 700px) {
      .ws-phases { grid-template-columns: 92px 1fr; }
      .ws-when { padding-left: 8px; }
    }

    /* ── Intro lead ── */
    .ws-intro {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      margin: 24px 0 14px;
      color: var(--foreground);
      font-weight: 600;
      font-size: 16px;
      letter-spacing: -0.02em;
      max-width: 540px;
    }

    /* ── Offering points ── */
    .ws-points {
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 560px;
      border-top: 1px solid var(--border);
    }
    .ws-points li {
      position: relative;
      padding: 14px 0 14px 20px;
      border-bottom: 1px solid color-mix(in oklab, var(--border) 50%, transparent);
      font-size: 14px;
      line-height: 22px;
      color: color-mix(in oklab, var(--foreground) 60%, transparent);
    }
    .ws-points li::before {
      content: "·";
      position: absolute;
      left: 0;
      top: 12px;
      color: var(--primary);
      font-size: 1.125rem;
      font-weight: 700;
      line-height: 1.2;
    }
    .ws-points li strong {
      display: block;
      font-family: 'Instrument Sans', system-ui, sans-serif;
      color: var(--foreground);
      font-weight: 600;
      font-size: 14px;
      letter-spacing: -0.01em;
      margin-bottom: 2px;
    }
    .ws-points-feat {
      background: oklch(from var(--primary) l c h / 0.08);
      margin-left: -14px;
      padding-left: 28px !important;
      padding-right: 14px;
      border-bottom: none !important;
    }
    /* Restore the next sibling's top edge so dropping the feat's bottom
       border doesn't leave it visually merged with the following item. */
    .ws-points-feat + li {
      border-top: 1px solid oklch(from var(--border) l c h / 0.3);
    }
    /* No bullet/bar on the highlighted item — the tinted background is
       enough on its own. */
    .ws-points-feat::before { display: none !important; }
    .ws-star {
      color: var(--primary);
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      font-weight: 500;
      margin-left: 6px;
      vertical-align: 1px;
    }

    /* ── OSS contributors card ──
       Wears the "branded stamp" treatment (was on commit-card): primary
       background, primary-foreground text, offset-stack shadow. */
    .ws-oss-note {
      width: 100%;
      padding: 24px;
      background: linear-gradient(135deg, color-mix(in oklab, var(--primary) 12%, var(--card)), var(--card));
      color: color-mix(in oklab, var(--foreground) 65%, transparent);
      border: 1px solid color-mix(in oklab, var(--primary) 20%, var(--border));
      border-radius: 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      line-height: 1.55;
      letter-spacing: 0.01em;
    }
    @media (min-width: 810px) {
      .ws-oss-note { padding: 32px; }
    }
    .ws-oss-note-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      color: var(--primary);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    /* Default accent across the page is primary; inside the colored OSS
       stamp it would disappear into the bg, so override to the stamp's
       text color with extra weight for emphasis instead. */
    .ws-accent { color: var(--primary); }
    .ws-oss-note .ws-accent {
      color: var(--primary);
      font-weight: 700;
    }

    /* ── Form card ── */
    .ws-form-card {
      width: 100%;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      position: relative;
      overflow: hidden;
    }
    @media (min-width: 810px) {
      .ws-form-card { padding: 32px; }
    }

    .ws-form-head {
      padding-bottom: 12px;
      margin-bottom: 16px;
      border-bottom: 1px solid color-mix(in oklab, var(--border) 50%, transparent);
    }
    .ws-form-title {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-weight: 600;
      font-size: 16px;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--foreground);
    }

    .ws-honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .ws-row-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 480px) { .ws-row-2 { grid-template-columns: 1fr; } }

    .ws-field {
      display: flex;
      flex-direction: column;
      margin-bottom: 10px;
    }
    .ws-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: color-mix(in oklab, var(--foreground) 30%, transparent);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 6px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .ws-opt {
      text-transform: none;
      letter-spacing: 0;
      color: color-mix(in oklab, var(--foreground) 25%, transparent);
      font-size: 11px;
      font-weight: 400;
    }

    .ws-field input,
    .ws-field textarea {
      width: 100%;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 8px 10px;
      font-family: inherit;
      font-size: 13px;
      color: var(--foreground);
      outline: none;
      transition: border-color 120ms ease, box-shadow 120ms ease;
    }
    .ws-field input::placeholder,
    .ws-field textarea::placeholder {
      color: color-mix(in oklab, var(--foreground) 25%, transparent);
    }
    .ws-field input:focus,
    .ws-field textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px oklch(from var(--primary) l c h / 0.15);
    }
    .ws-field textarea {
      resize: vertical;
      min-height: 64px;
      line-height: 1.5;
    }
    .ws-err {
      color: var(--destructive);
      font-family: var(--font-mono);
      font-size: 0.625rem;
      margin-top: 5px;
      letter-spacing: 0.01em;
    }

    /* ── Pills ── */
    .ws-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }
    .ws-pill {
      border: 1px solid var(--border);
      background: var(--background);
      color: color-mix(in oklab, var(--foreground) 65%, transparent);
      padding: 5px 10px;
      border-radius: 6px;
      font-family: inherit;
      font-size: 13px;
      cursor: pointer;
      user-select: none;
      transition: border-color 120ms ease, background 120ms ease, color 120ms ease, transform 100ms ease;
    }
    .ws-pill:hover {
      border-color: oklch(from var(--primary) l c h / 0.5);
      color: var(--foreground);
    }
    .ws-pill:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px oklch(from var(--primary) l c h / 0.18);
    }
    .ws-pill:active { transform: scale(0.97); }
    .ws-pill.on {
      background: var(--foreground);
      border-color: var(--foreground);
      color: var(--background);
    }

    /* ── Contributor checkbox ── */
    .ws-check-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px 14px;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      color: color-mix(in oklab, var(--foreground) 65%, transparent);
      line-height: 1.45;
      user-select: none;
      margin-bottom: 6px;
      transition: border-color 140ms ease, background 140ms ease;
    }
    .ws-check-row:hover { border-color: oklch(from var(--primary) l c h / 0.5); }
    .ws-check-row:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px oklch(from var(--primary) l c h / 0.18);
    }
    .ws-check-row.on {
      background: oklch(from var(--primary) l c h / 0.1);
      border-color: var(--primary);
      color: var(--foreground);
    }
    .ws-check-row .ws-box {
      width: 14px;
      height: 14px;
      border: 1px solid var(--border);
      background: var(--card);
      border-radius: 2px;
      flex-shrink: 0;
      display: grid;
      place-items: center;
      color: transparent;
      margin-top: 1px;
    }
    .ws-check-row .ws-box svg { width: 10px; height: 10px; }
    .ws-check-row.on .ws-box {
      background: var(--primary);
      border-color: var(--primary);
      color: var(--primary-foreground);
    }

    .ws-contrib-note {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: color-mix(in oklab, var(--foreground) 35%, transparent);
      line-height: 1.5;
      letter-spacing: 0.02em;
      padding: 4px 14px 0;
      margin: 0 0 14px;
    }

    /* ── Turnstile slot (almost always invisible) ── */
    .ws-turnstile {
      margin-top: 10px;
      min-height: 0;
      display: flex;
      justify-content: center;
    }
    .ws-turnstile:empty { margin-top: 0; }

    /* ── Submit ── */
    .ws-form-foot {
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
      display: flex;
    }
    .ws-submit {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      height: 40px;
      padding: 0 18px;
      background: var(--foreground);
      color: var(--background);
      border: 1px solid var(--foreground);
      border-radius: 4px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: -0.005em;
      cursor: pointer;
      transition: background 120ms ease, transform 100ms ease;
      white-space: nowrap;
    }
    .ws-submit:hover { background: oklch(from var(--primary) l c h / 0.9); }
    .ws-submit:active { transform: translateY(1px); }
    .ws-submit:disabled { cursor: not-allowed; }
    .ws-arrow { transition: transform 160ms ease; }
    .ws-submit:hover .ws-arrow { transform: translateX(3px); }

    /* Idle vs busy children — only one is visible at a time. The button
       keeps its size both ways (idle layout determines the box). */
    .ws-submit-idle,
    .ws-submit-busy {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .ws-submit-busy {
      display: none;
      color: var(--primary-foreground);
    }
    .ws-submit.is-loading .ws-submit-idle { display: none; }
    .ws-submit.is-loading .ws-submit-busy { display: inline-flex; }
    .ws-submit.is-loading { background: oklch(from var(--primary) l c h / 0.85); }

    .ws-spinner {
      width: 14px;
      height: 14px;
      border: 2px solid currentColor;
      border-top-color: transparent;
      border-radius: 50%;
      animation: ws-spin 0.65s linear infinite;
    }
    @keyframes ws-spin {
      to { transform: rotate(360deg); }
    }

    /* ── Success state ── */
    .ws-success { display: none; }
    .ws-form-card.ws-submitted .ws-form-body { display: none; }
    .ws-form-card.ws-submitted .ws-success {
      display: block;
      animation: ws-fade-up 0.35s cubic-bezier(0.23, 1, 0.32, 1);
    }
    @keyframes ws-fade-up {
      from { opacity: 0; transform: translateY(4px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .ws-ok {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .ws-dot {
      width: 7px;
      height: 7px;
      background: var(--primary);
      border-radius: 50%;
    }
    .ws-success-title {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-weight: 600;
      font-size: 1.25rem;
      line-height: 1.2;
      letter-spacing: -0.01em;
      margin: 0 0 10px;
      color: var(--foreground);
    }
    .ws-success-title em { color: var(--primary); font-style: normal; }
    .ws-success p {
      font-size: 0.875rem;
      color: oklch(from var(--foreground) l c h / 0.78);
      line-height: 1.55;
      margin: 0 0 12px;
    }
    .ws-success p strong { color: var(--foreground); font-weight: 500; }

    .ws-receipt {
      margin-top: 18px;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 12px 14px;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }
    .ws-r {
      display: flex;
      justify-content: space-between;
      padding: 4px 0;
      border-bottom: 1px dashed oklch(from var(--border) l c h / 0.5);
    }
    .ws-r:last-child { border-bottom: none; }
    .ws-r-k {
      color: var(--muted-foreground);
      text-transform: uppercase;
      font-size: 0.625rem;
      letter-spacing: 0.05em;
    }
    .ws-r-v {
      color: var(--foreground);
      max-width: 60%;
      text-align: right;
    }

    /* ── Commitment card ──
       Now the subtle bordered card (color pattern swapped with the OSS
       contributors stamp above). bg-card on a thin border, foreground text
       with primary highlights — sits quietly under the form. */
    .ws-commit-card {
      /* now inside .ws-card, no standalone styling needed */
    }
    .ws-commit-tag {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 12px;
    }
    .ws-commit-msg {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.4;
      letter-spacing: -0.01em;
      color: var(--foreground);
      margin: 0;
    }
    .ws-commit-msg em {
      font-style: normal;
      color: var(--primary);
      font-weight: 600;
    }
  </style>
</Base>
